#!/bin/bash
# summarize - 简化版文章/URL摘要工具
# 用法: summarize <URL> 或 summarize <文件路径>

set -e

URL="$1"

if [ -z "$URL" ]; then
    echo "用法: summarize <URL>"
    echo "      summarize <文件路径>"
    exit 1
fi

# 检查是否为URL
if [[ "$URL" =~ ^https?:// ]]; then
    # 使用curl获取网页内容并提取文本
    echo "正在获取: $URL"
    curl -sL "$URL" | \
        sed 's/<[^>]*>//g' | \
        tr -s '\n\r\t' '\n' | \
        head -100
else
    # 本地文件
    if [ -f "$URL" ]; then
        cat "$URL" | head -100
    else
        echo "错误: 文件不存在 - $URL"
        exit 1
    fi
fi
